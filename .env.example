# ============================================================================
# AI Job Bot — environment variables
# Copy to .env.local and fill in real values as each phase wires them up.
# All NEXT_PUBLIC_* vars ship to the client bundle; never put secrets there.
# ============================================================================

# ---- Phase 0 --------------------------------------------------------------
NODE_ENV=development

# ---- Phase 1 — Telegram bot + auth ----------------------------------------
# phase: 1 — BotFather token for the Telegram bot
TELEGRAM_BOT_TOKEN=
# phase: 1 — shared secret for webhook X-Telegram-Bot-Api-Secret-Token header
TELEGRAM_WEBHOOK_SECRET_TOKEN=
# phase: 1 — public URL of the Mini App (used in bot inline keyboard)
NEXT_PUBLIC_MINI_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_URL=http://localhost:3000

# phase: 1 — Supabase (server side)
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
# phase: 1 — HMAC secret used to sign our own Supabase JWTs
SUPABASE_JWT_SECRET=

# phase: 1 — Supabase (client side — public, safe to expose)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# ---- Phase 2 — AI resume parse --------------------------------------------
# phase: 2 — OpenAI API key (gpt-5.1 per ADR 0006). Kept optional so Vercel
# preview builds succeed before the key is set.
OPENAI_API_KEY=
# phase: 2 — override the default model id (default: gpt-5.1)
OPENAI_RESUME_MODEL=gpt-5.1
# phase: 2 — Anthropic vars kept for optional fallback / future re-provisioning.
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-5

# ---- Phase 3 — ESCO taxonomy ----------------------------------------------
# phase: 3 — ESCO public API base URL (EU occupations/skills taxonomy)
ESCO_API_BASE=https://ec.europa.eu/esco/api

# ---- Phase 4 — Payments (TON) ---------------------------------------------
# phase: 4 — tonapi.io key for server-side on-chain tx verification
TON_API_KEY=
# phase: 4 — testnet | mainnet
TON_NETWORK=testnet
# phase: 4 — publicly hosted tonconnect-manifest.json
TON_MANIFEST_URL=
NEXT_PUBLIC_TONCONNECT_MANIFEST_URL=
# phase: 4 — wallet address that receives campaign payments
TON_PAYMENT_RECIPIENT_ADDRESS=

# ---- Phase 7 — Observability + deploy -------------------------------------
# phase: 7 — Sentry DSN (server)
SENTRY_DSN=
# phase: 7 — Sentry DSN (client)
NEXT_PUBLIC_SENTRY_DSN=
# phase: 7 — Sentry auth token for source map upload during CI
SENTRY_AUTH_TOKEN=
# phase: 7 — set automatically by Vercel at deploy time
VERCEL_URL=
