# Supabase (service-role — bypasses RLS, owner-only)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=

# Dashboard auth (HTTP Basic)
DASHBOARD_USER=admin
DASHBOARD_PASSWORD=replace-with-strong-password

# Bot (for broadcast messages)
TELEGRAM_BOT_TOKEN=

# Read-only display (matches the Mini App project)
TON_NETWORK=mainnet
STARS_TEST_MODE=
STARS_TEST_AMOUNT=
